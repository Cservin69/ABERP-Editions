# ABERP seller config — operator-facing template.
#
# Copy this file to ~/.aberp/<tenant>/seller.toml and fill in your
# real company data. The tenant directory mirrors the `--tenant`
# argument the binary is launched with (default: `test`).
#
# Example:
#
#     cp samples/seller.toml.example ~/.aberp/test/seller.toml
#     # then edit ~/.aberp/test/seller.toml in place
#
# Today (PR-50 / session 70) only the bottom `bank_*` block is
# consumed at runtime — by the `print-invoice` PDF renderer
# (`apps/aberp/src/print_invoice.rs::read_seller_toml`), which folds
# the IBAN + bank-name + SWIFT lines into the printed invoice
# footer. The top `[seller]` + `[seller.address]` blocks are
# documented here for forward compatibility: PR-51 (the SetupWizard
# extension) will route seller-identity fields (legal name, tax
# number, address) through this file instead of having the operator
# retype them on every issuance. Until then, those fields flow via
# the SPA Issue-invoice form's Supplier section.
#
# Hungarian tax-number format (ADÓSZÁM): `xxxxxxxx-y-zz`
#   - xxxxxxxx — 8-digit base taxpayer id
#   - y        — 1-digit VAT code
#   - zz       — 2-digit county code
# Example: `24904362-2-41`.
#
# A malformed tax number on the SPA Issue form surfaces as a typed
# 400 `missing_seller_config` error with this file's path + the
# sample path as actionable hints.

# ── PR-51 (forward-looking) — seller identity ─────────────────────
# Uncomment + populate when PR-51 lands. Leave commented until then;
# the runtime ignores the entries today.
#
# [seller]
# legal_name    = "Áben Consulting KFT."
# tax_number    = "24904362-2-41"      # required, Hungarian xxxxxxxx-y-zz
# eu_vat_number = "HU24904362"         # optional, EU cross-border invoices only
#
# [seller.address]
# country_code = "HU"
# postal_code  = "1037"
# city         = "Budapest"
# street       = "Visszatérő köz 6"

# ── PR-44ε.1 / session 57 — bank info (LIVE; consumed today) ──────
# Flat-key shape (matching `SellerToml` in print_invoice.rs). Each
# field is optional — the PDF renderer hides empty rows.
#
# NOTE (PR-71 / session 93 / ADR-0040): this flat-root form is now
# LEGACY. The PR-71 `seller_banks` loader folds it on load into a
# single-element `[[seller.banks]]` array with `default = true`
# and a SWIFT-inferred currency (HU country code → HUF). The
# existing PDF renderer + `GET /api/seller-info` route still read
# the flat keys directly; PR-B (UI) + PR-D (NAV/PDF render) will
# swap them to the new array form. Until then, an operator copying
# this template keeps a working PDF + Settings page.
bank_account_number = "12345678-12345678-12345678"
iban                = "LT14 3250 0448 1318 6860"
bank_name           = "Revolut"
swift_bic           = "REVOLT21"

# ── PR-71 / session 93 — multi-bank-account schema (forward-looking)
#
# Once PR-B + PR-D land, the CANONICAL shape is one
# `[[seller.banks]]` array-of-tables entry per (currency,
# account_number) pair, replacing the four flat keys above:
#
#   [[seller.banks]]
#   currency       = "HUF"
#   account_number = "12345678-12345678-12345678"
#   bank_name      = "Erste Bank"
#   swift_bic      = "GIBAHUHB"
#   default        = true
#
#   [[seller.banks]]
#   currency       = "EUR"
#   account_number = "HU12-3456-7890-1234-5678-9012-3456"
#   bank_name      = "Erste Bank"
#   swift_bic      = "GIBAHUHB"
#   default        = true
#
# Each entry requires `currency` (closed-vocab "HUF" / "EUR" per
# ADR-0037), `account_number`, `bank_name`, `swift_bic`, and a
# bool `default`. Per ADR-0040 §2 the loader enforces EXACTLY ONE
# `default = true` per currency that has entries (two HUF
# defaults or zero HUF defaults loud-fail at load). PR-B's
# Tenant Settings page is the operator's surface for writing this
# form once PR-B ships.
